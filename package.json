{
	"name": "dragoteryx-xyz-nuxt",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "nuxt build",
		"dev": "nuxt dev",
		"generate": "nuxt generate --preset github-pages",
		"preview": "nuxt preview",
		"postinstall": "nuxt prepare",
		"format": "prettier --write .",
		"build-wasm": "wasm-pack build app/wasm --target bundler"
	},
	"prettier": {
		"useTabs": true,
		"printWidth": 120,
		"endOfLine": "auto",
		"arrowParens": "avoid",
		"vueIndentScriptAndStyle": true
	},
	"dependencies": {
		"@nuxtjs/color-mode": "4.0.0",
		"@pinia/nuxt": "0.11.3",
		"@vueuse/nuxt": "14.2.1",
		"animate.css": "^4.1.1",
		"color-convert": "^3.1.3",
		"lucide-vue-next": "^0.577.0",
		"nuxt": "^4.4.2",
		"pinia": "^3.0.4",
		"vue": "^3.5.30",
		"vue-router": "^5.0.3"
	},
	"devDependencies": {
		"prettier": "^3.8.1",
		"sass-embedded": "^1.98.0",
		"vite-plugin-wasm": "^3.6.0",
		"wasm-pack": "^0.14.0"
	}
}
